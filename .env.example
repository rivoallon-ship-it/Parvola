# Configuration de l'application Talent Review

# Supabase (public keys — secured by Row-Level Security)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# NOTE: The Anthropic API key is stored ONLY in the Supabase Edge Function
# secrets (server-side). Do NOT add it here as a VITE_ variable — it would
# be exposed in the browser bundle.
# To set it: supabase secrets set ANTHROPIC_API_KEY=sk-ant-...

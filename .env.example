# Configuration de l'application Talent Review

# API Anthropic pour la génération d'objectifs avec l'IA
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# URL de l'API backend (optionnel - si vous utilisez un backend)
VITE_API_BASE_URL=http://localhost:4000/api

# Mode de stockage: 'local' pour localStorage, 'api' pour backend
VITE_STORAGE_MODE=local
